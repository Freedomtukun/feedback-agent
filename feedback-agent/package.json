{
  "name": "feedback-agent",
  "version": "1.5.0",
  "description": "通用反馈型智能体：瑜伽体式识别、评分、骨架图、建议、TTS 等多场景",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start:local": "node local-runner.js",
    "start:dev": "NODE_ENV=development node local-runner.js",

    "validate": "node scripts/validate-structure.js",
    "test:routes": "node test-routes.js",
    "test:all": "npm run validate && npm run test:routes",
    "test": "npm run test:all",

    "lint": "eslint .",

    "build:zip": "zip -r feedback-agent.zip . -x '*.git*' 'node_modules/*' 'local-runner.js' '*.log' 'test/*' 'tests/*' '*.DS_Store'",
    "deploy:zip": "npm run build:zip && echo '部署包已生成: feedback-agent.zip'",
    "deploy:tcb": "tcb fn deploy feedback-agent --force"
  },
  "dependencies": {
    "axios": "^1.10.0",
    "cos-nodejs-sdk-v5": "^2.15.1",
    "form-data": "^4.0.4",
    "md5": "^2.3.0",
    "mime-types": "^2.1.35",
    "tencentcloud-sdk-nodejs": "~4.0.815",
    "uuid": "^9.0.0",
    "tmp": "^0.2.1",
    "@hapi/joi": "^17.1.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  },
  "keywords": [
    "feedback",
    "ai-agent",
    "yoga",
    "pose-detection",
    "llm",
    "tts",
    "serverless",
    "tencent-cloud"
  ],
  "author": "Your Name",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "your-repo-url"
  }
}
